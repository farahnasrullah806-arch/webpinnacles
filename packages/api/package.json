{
  "name": "@webpinnacles/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@webpinnacles/contracts": "workspace:*",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.47.2",
    "drizzle-orm": "^0.41.0",
    "fastify": "^5.2.2",
    "nanoid": "^5.1.5",
    "pg": "^8.14.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.3",
    "vitest": "^3.0.8"
  }
}
