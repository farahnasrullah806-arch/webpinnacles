{
  "name": "webpinnacles",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=./apps/*",
    "build": "turbo run build --filter=./apps/*",
    "build:web": "turbo run build --filter=web",
    "build:cms": "turbo run build --filter=cms-admin",
    "build:api": "turbo run build --filter=api",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "node -e \"if(process.env.CI !== 'true' && process.env.VERCEL !== '1'){require('child_process').execSync('husky',{stdio:'inherit'})}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": "prettier --write"
  }
}
